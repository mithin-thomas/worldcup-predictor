# Copy to backend/.env and frontend/.env (both gitignored), then fill the REPLACE_* values.
# The backend auto-loads backend/.env in dev (godotenv); Vite auto-loads frontend/.env.

# ============ Backend (backend/.env) ============
APP_ENV=development
HTTP_PORT=8000

# Database — matches deploy/docker-compose.yml (compose project: sayscore)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=wcp
DB_PASSWORD=wcp
DB_NAME=wcp

# Signs the session cookie. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-random-32-byte-string

# Google Workspace SSO.
# NOTE: SayScore uses the Google Identity Services *ID-token* flow, which needs
# ONLY the client ID (used as the token audience). There is intentionally NO
# GOOGLE_CLIENT_SECRET and NO redirect URI — those belong to the OAuth
# authorization-code/server-redirect flow, which this app does not use.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=sayonetech.com
SEED_ADMIN_EMAILS=you@sayonetech.com

# Static fixtures dataset — the committed CSVs in data/ (no API key needed).
# Override only if you relocate the dataset.
SEED_DATA_DIR=./data

TZ=Asia/Kolkata

# ============ Frontend (frontend/.env) ============
# Same client ID as the backend. No client secret on the frontend either.
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
VITE_API_BASE_URL=/api
