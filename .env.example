# Copy to backend/.env and frontend/.env (both gitignored), then fill the REPLACE_* values.
# The backend auto-loads backend/.env in dev (godotenv); Vite auto-loads frontend/.env.

# ============ Backend (backend/.env) ============
APP_ENV=development
HTTP_PORT=8000

# Database — matches deploy/docker-compose.yml (compose project: sayscore)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=wcp
DB_PASSWORD=wcp
DB_NAME=wcp

# Signs the session cookie. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-random-32-byte-string

# Google Workspace SSO.
# NOTE: SayScore uses the Google Identity Services *ID-token* flow, which needs
# ONLY the client ID (used as the token audience). There is intentionally NO
# GOOGLE_CLIENT_SECRET and NO redirect URI — those belong to the OAuth
# authorization-code/server-redirect flow, which this app does not use.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=sayonetech.com
SEED_ADMIN_EMAILS=you@sayonetech.com

# Static fixtures dataset — the committed CSVs in data/ (no API key needed).
# Override only if you relocate the dataset.
SEED_DATA_DIR=./data

# Results source — football-data.org v4 (competition WC). Register for a free key
# at https://www.football-data.org/client/register. Empty = results-ingest
# scheduler disabled (server still boots). RESULTS_CRON is 5-field, IST.
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
RESULTS_CRON="0 3,8,13 * * *"
WEEKLY_CRON="30 13 * * 1"
# Set false to stop the SCHEDULED results-ingest from auto-running (the manual
# admin trigger still works). The Docker stack sets this false so seeded demo
# data isn't overwritten by live results; leave true for a real deployment.
RESULTS_CRON_ENABLED=true

# Optional Slack Incoming Webhook — posts a one-line status to a channel after
# each results-ingest / weekly-winner / bonus-score run (scheduled + manual), so
# you can confirm the cron is alive. Empty = no Slack (jobs still run). Create
# one at https://api.slack.com/apps → Incoming Webhooks. Never commit a real URL.
SLACK_WEBHOOK_URL=

TZ=Asia/Kolkata

# ============ Frontend (frontend/.env) ============
# Same client ID as the backend. No client secret on the frontend either.
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
VITE_API_BASE_URL=/api
# MadCrow chatbot widget — internal testing only. Get the assistant ID from the MadCrow dashboard.
VITE_MADCROW_ASSISTANT_ID=
