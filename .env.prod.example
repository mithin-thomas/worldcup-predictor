# SayScore PRODUCTION env — copy to .env.prod and fill in. NEVER commit .env.prod.
#   Host deploy (pull prebuilt images from ECR):  make deploy-prod

# ---- Images (full refs incl. registry+tag; keeps the account ID out of the
#       public compose file). On the host, `make deploy-prod` pulls these.
#       REQUIRED — the prod compose pulls these; it does not build. ----
# e.g. 123456789012.dkr.ecr.ap-south-1.amazonaws.com/sayscore:backend-latest
BACKEND_IMAGE=<account>.dkr.ecr.<region>.amazonaws.com/sayscore:backend-latest
FRONTEND_IMAGE=<account>.dkr.ecr.<region>.amazonaws.com/sayscore:frontend-latest

# Public hostname for the app. Caddy auto-provisions a Let's Encrypt cert for it,
# so DNS must point at this host and ports 80 + 443 must be reachable.
# Use ":80" for a local, no-TLS smoke test.
SITE_ADDRESS=sayscore.example.com

# ---- Database (use strong, unique values) ----
DB_NAME=wcp
DB_USER=wcp
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-strong-root

# ---- Backend secrets ----
# Session cookie signing key — generate with: openssl rand -base64 48
SESSION_SECRET=

# Google Workspace SSO (ID-token flow — client id only, no secret). The prod
# origin (https://SITE_ADDRESS) must be an Authorized JavaScript origin on the
# OAuth client. The same id is baked into the frontend bundle at build time.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=sayonetech.com
SEED_ADMIN_EMAILS=admin@sayonetech.com

# ---- Results sync (football-data.org) ----
# Leave the key empty to disable the results-ingest scheduler. In prod the
# schedule is ON by default (unlike the local stack).
FOOTBALL_DATA_API_KEY=
RESULTS_CRON_ENABLED=true

# ---- Optional Slack Incoming Webhook for cron notifications ----
SLACK_WEBHOOK_URL=

# ---- Chat assistant (OpenAI, prompt-only) ----
# Leave OPENAI_API_KEY blank to disable chat (POST /api/chat returns 503).
# The system prompt is read from a file MOUNTED into the backend container at
# /app/chat-system.txt (see deploy/docker-compose.prod.yml). Place chat-system.txt
# on the host at the repo root (one level above deploy/) before `make deploy-prod`;
# it is gitignored, so copy it up manually (e.g. scp). Without it, chat stays off.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini-2025-04-14
OPENAI_TEMPERATURE=0.8
