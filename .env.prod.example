# SayScore PRODUCTION env — copy to .env.prod and fill in. NEVER commit .env.prod.
#   docker compose --env-file .env.prod -p sayscore-prod -f deploy/docker-compose.prod.yml up -d --build
#   (or: make up-prod)

# Public hostname for the app. Caddy auto-provisions a Let's Encrypt cert for it,
# so DNS must point at this host and ports 80 + 443 must be reachable.
# Use ":80" for a local, no-TLS smoke test.
SITE_ADDRESS=sayscore.example.com

# ---- Database (use strong, unique values) ----
DB_NAME=wcp
DB_USER=wcp
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-strong-root

# ---- Backend secrets ----
# Session cookie signing key — generate with: openssl rand -base64 48
SESSION_SECRET=

# Google Workspace SSO (ID-token flow — client id only, no secret). The prod
# origin (https://SITE_ADDRESS) must be an Authorized JavaScript origin on the
# OAuth client. The same id is baked into the frontend bundle at build time.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=sayonetech.com
SEED_ADMIN_EMAILS=admin@sayonetech.com

# ---- Results sync (football-data.org) ----
# Leave the key empty to disable the results-ingest scheduler. In prod the
# schedule is ON by default (unlike the local stack).
FOOTBALL_DATA_API_KEY=
RESULTS_CRON_ENABLED=true

# ---- Optional Slack Incoming Webhook for cron notifications ----
SLACK_WEBHOOK_URL=
